# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Microsoft Foundry project connection string
# Found in: Foundry portal > your project > Overview > Project connection string
FOUNDRY_PROJECT_CONNECTION=<your-project-connection-string>

# Model deployment name
# Found in: Foundry portal > your project > Models + endpoints
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o
