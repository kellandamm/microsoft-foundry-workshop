# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Microsoft Foundry project connection string
FOUNDRY_PROJECT_CONNECTION=<your-project-connection-string>

# Model deployment name
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o

# Agent ID — set this after completing Lab 1 (creating the agent)
# Found in the output of main_agent.py, or in the Foundry portal
AGENT_ID=<your-agent-id>
